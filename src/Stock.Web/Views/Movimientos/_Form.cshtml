@using Stock.Web.Services
@model Stock.Web.Models.MovimientoViewModel

<div asp-validation-summary="All" class="text-danger mb-3"></div>
<input type="hidden" asp-for="MovimientoId" />

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <label asp-for="Tipo" class="form-label"></label>
        <select asp-for="Tipo" asp-items="Html.GetEnumSelectList<TipoMovimiento>()" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <label asp-for="Numero" class="form-label"></label>
        <input asp-for="Numero" class="form-control" type="number" min="1" />
        <span asp-validation-for="Numero" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Fecha" class="form-label"></label>
        <input asp-for="Fecha" class="form-control" />
    </div>
</div>

<h2 class="h5">Detalle</h2>
<div class="table-responsive">
    <table class="table align-middle" id="tabla-detalle" data-lookup-url="@Url.Action("BuscarArticulo", "Movimientos")">
        <thead>
            <tr>
                <th style="width:30%">Código</th>
                <th style="width:20%">Cantidad</th>
                <th style="width:20%">Precio Unitario</th>
                <th style="width:20%" class="text-end">Precio Total</th>
                <th style="width:10%"></th>
            </tr>
        </thead>
        <tbody id="cuerpo-detalle">
            @for (var i = 0; i < Model.Detalles.Count; i++)
            {
                <tr class="linea-detalle">
                    <td>
                        <input name="Detalles[@i].Codigo" value="@Model.Detalles[i].Codigo" class="form-control codigo" autocomplete="off" />
                        <div class="form-text descripcion-articulo"></div>
                    </td>
                    <td><input name="Detalles[@i].Cantidad" value="@Model.Detalles[i].Cantidad" class="form-control cantidad" type="number" min="1" /></td>
                    <td><input name="Detalles[@i].PrecioUnitario" value="@Model.Detalles[i].PrecioUnitario" class="form-control precio" type="number" step="0.01" min="0" /></td>
                    <td class="text-end total-linea">0.00</td>
                    <td><button type="button" class="btn btn-sm btn-outline-danger quitar-linea">Quitar</button></td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="3" class="text-end">Total</th>
                <th class="text-end" id="total-general">0.00</th>
                <th></th>
            </tr>
        </tfoot>
    </table>
</div>

<button type="button" class="btn btn-outline-secondary btn-sm" id="agregar-linea">Agregar línea</button>

@* Fila plantilla para nuevas líneas: __INDEX__ se reemplaza por el índice real al agregar. *@
<template id="plantilla-linea">
    <tr class="linea-detalle">
        <td>
            <input name="Detalles[__INDEX__].Codigo" class="form-control codigo" autocomplete="off" />
            <div class="form-text descripcion-articulo"></div>
        </td>
        <td><input name="Detalles[__INDEX__].Cantidad" value="1" class="form-control cantidad" type="number" min="1" /></td>
        <td><input name="Detalles[__INDEX__].PrecioUnitario" value="0" class="form-control precio" type="number" step="0.01" min="0" /></td>
        <td class="text-end total-linea">0.00</td>
        <td><button type="button" class="btn btn-sm btn-outline-danger quitar-linea">Quitar</button></td>
    </tr>
</template>

<script>
    (function () {
        var tabla = document.getElementById("tabla-detalle");
        var cuerpo = document.getElementById("cuerpo-detalle");
        var plantilla = document.getElementById("plantilla-linea");
        var totalGeneral = document.getElementById("total-general");
        var tipoSelect = document.getElementById("Tipo");
        var lookupUrl = tabla.getAttribute("data-lookup-url");
        var form = tabla.closest("form");

        function esVenta() {
            var opcion = tipoSelect.options[tipoSelect.selectedIndex];
            return (opcion ? opcion.text : "").trim().toLowerCase() === "venta";
        }

        function renumerar() {
            cuerpo.querySelectorAll("tr.linea-detalle").forEach(function (fila, i) {
                fila.querySelectorAll("input").forEach(function (input) {
                    input.name = input.name.replace(/Detalles\[(\d+|__INDEX__)\]/, "Detalles[" + i + "]");
                });
            });
        }

        function recalcular() {
            var total = 0;
            cuerpo.querySelectorAll("tr.linea-detalle").forEach(function (fila) {
                var cant = parseFloat(fila.querySelector(".cantidad").value);
                var precio = parseFloat(fila.querySelector(".precio").value);
                var sub = (isNaN(cant) || isNaN(precio)) ? 0 : cant * precio;
                fila.querySelector(".total-linea").textContent = sub.toFixed(2);
                total += sub;
            });
            totalGeneral.textContent = total.toFixed(2);
        }

        // Aplica a la fila el precio sugerido según el tipo (compra: costo, venta: venta),
        // pero sólo si el usuario no lo editó a mano desde la última sugerencia.
        function aplicarPrecioSugerido(fila) {
            var precioInput = fila.querySelector(".precio");
            var costo = precioInput.getAttribute("data-costo");
            var venta = precioInput.getAttribute("data-venta");
            if (costo === null || venta === null) {
                return;
            }

            var sugerido = esVenta() ? venta : costo;
            var autoAnterior = precioInput.getAttribute("data-auto");
            if (autoAnterior === null || precioInput.value === autoAnterior) {
                precioInput.value = sugerido;
                precioInput.setAttribute("data-auto", sugerido);
            }
        }

        function mostrarDescripcion(fila, texto, esError) {
            var etiqueta = fila.querySelector(".descripcion-articulo");
            var codigoInput = fila.querySelector(".codigo");
            etiqueta.textContent = texto;
            etiqueta.classList.toggle("text-danger", !!esError);
            etiqueta.classList.toggle("text-success", !esError && !!texto);
            codigoInput.classList.toggle("is-invalid", !!esError);
        }

        // Resuelve el código contra la API: muestra la descripción y sugiere el precio.
        function resolverCodigo(fila) {
            var codigoInput = fila.querySelector(".codigo");
            var codigo = codigoInput.value.trim();
            var precioInput = fila.querySelector(".precio");

            if (codigo === "") {
                precioInput.removeAttribute("data-costo");
                precioInput.removeAttribute("data-venta");
                mostrarDescripcion(fila, "", false);
                return;
            }

            fetch(lookupUrl + "?codigo=" + encodeURIComponent(codigo), { headers: { "Accept": "application/json" } })
                .then(function (resp) { return resp.ok ? resp.json() : null; })
                .then(function (art) {
                    if (!art) {
                        precioInput.removeAttribute("data-costo");
                        precioInput.removeAttribute("data-venta");
                        mostrarDescripcion(fila, "No existe un artículo con ese código.", true);
                        return;
                    }
                    precioInput.setAttribute("data-costo", art.precioCosto);
                    precioInput.setAttribute("data-venta", art.precioVenta);
                    mostrarDescripcion(fila, art.descripcion, false);
                    aplicarPrecioSugerido(fila);
                    recalcular();
                })
                .catch(function () { /* si el lookup falla, la validación del servidor sigue cubriendo el caso */ });
        }

        function agregar() {
            var indice = cuerpo.querySelectorAll("tr.linea-detalle").length;
            var html = plantilla.innerHTML.replace(/__INDEX__/g, indice);
            var contenedor = document.createElement("tbody");
            contenedor.innerHTML = html.trim();
            cuerpo.appendChild(contenedor.firstChild);
            recalcular();
        }

        function quitar(fila) {
            fila.remove();
            renumerar();
            recalcular();
        }

        document.getElementById("agregar-linea").addEventListener("click", agregar);

        cuerpo.addEventListener("click", function (e) {
            if (e.target.classList.contains("quitar-linea")) {
                quitar(e.target.closest("tr.linea-detalle"));
            }
        });

        cuerpo.addEventListener("input", function (e) {
            if (e.target.classList.contains("cantidad") || e.target.classList.contains("precio")) {
                recalcular();
            }
        });

        // El lookup se dispara al salir del campo código (no en cada tecla).
        cuerpo.addEventListener("change", function (e) {
            if (e.target.classList.contains("codigo")) {
                resolverCodigo(e.target.closest("tr.linea-detalle"));
            }
        });

        // Al cambiar el tipo, refrescamos el precio sugerido de cada línea ya resuelta.
        tipoSelect.addEventListener("change", function () {
            cuerpo.querySelectorAll("tr.linea-detalle").forEach(aplicarPrecioSugerido);
            recalcular();
        });

        // No dejamos enviar sin al menos una línea con código: el servidor igual lo rechaza,
        // pero así el usuario lo ve al instante.
        form.addEventListener("submit", function (e) {
            var conCodigo = Array.from(cuerpo.querySelectorAll(".codigo"))
                .some(function (input) { return input.value.trim() !== ""; });
            if (!conCodigo) {
                e.preventDefault();
                alert("Agregá al menos una línea de detalle con su código.");
            }
        });

        // Resolvemos las líneas que vienen precargadas (edición) para mostrar su descripción.
        cuerpo.querySelectorAll("tr.linea-detalle").forEach(function (fila) {
            if (fila.querySelector(".codigo").value.trim() !== "") {
                resolverCodigo(fila);
            }
        });

        recalcular();
    })();
</script>
