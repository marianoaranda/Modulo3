@using Stock.Web.Services
@model Stock.Web.Models.MovimientoViewModel

<div asp-validation-summary="All" class="text-danger mb-3"></div>
<input type="hidden" asp-for="MovimientoId" />

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <label asp-for="Tipo" class="form-label"></label>
        <select asp-for="Tipo" asp-items="Html.GetEnumSelectList<TipoMovimiento>()" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <label asp-for="Numero" class="form-label"></label>
        <input asp-for="Numero" class="form-control" type="number" min="1" />
        <span asp-validation-for="Numero" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Fecha" class="form-label"></label>
        <input asp-for="Fecha" class="form-control" />
    </div>
</div>

<h2 class="h5">Detalle</h2>
<div class="table-responsive">
    <table class="table align-middle" id="tabla-detalle">
        <thead>
            <tr>
                <th style="width:30%">Código</th>
                <th style="width:20%">Cantidad</th>
                <th style="width:20%">Precio Unitario</th>
                <th style="width:20%" class="text-end">Precio Total</th>
                <th style="width:10%"></th>
            </tr>
        </thead>
        <tbody id="cuerpo-detalle">
            @for (var i = 0; i < Model.Detalles.Count; i++)
            {
                <tr class="linea-detalle">
                    <td><input name="Detalles[@i].Codigo" value="@Model.Detalles[i].Codigo" class="form-control" /></td>
                    <td><input name="Detalles[@i].Cantidad" value="@Model.Detalles[i].Cantidad" class="form-control cantidad" type="number" min="1" /></td>
                    <td><input name="Detalles[@i].PrecioUnitario" value="@Model.Detalles[i].PrecioUnitario" class="form-control precio" type="number" step="0.01" min="0" /></td>
                    <td class="text-end total-linea">0.00</td>
                    <td><button type="button" class="btn btn-sm btn-outline-danger quitar-linea">Quitar</button></td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <th colspan="3" class="text-end">Total</th>
                <th class="text-end" id="total-general">0.00</th>
                <th></th>
            </tr>
        </tfoot>
    </table>
</div>

<button type="button" class="btn btn-outline-secondary btn-sm" id="agregar-linea">Agregar línea</button>

@* Fila plantilla para nuevas líneas: __INDEX__ se reemplaza por el índice real al agregar. *@
<template id="plantilla-linea">
    <tr class="linea-detalle">
        <td><input name="Detalles[__INDEX__].Codigo" class="form-control" /></td>
        <td><input name="Detalles[__INDEX__].Cantidad" value="1" class="form-control cantidad" type="number" min="1" /></td>
        <td><input name="Detalles[__INDEX__].PrecioUnitario" value="0" class="form-control precio" type="number" step="0.01" min="0" /></td>
        <td class="text-end total-linea">0.00</td>
        <td><button type="button" class="btn btn-sm btn-outline-danger quitar-linea">Quitar</button></td>
    </tr>
</template>

<script>
    (function () {
        var cuerpo = document.getElementById("cuerpo-detalle");
        var plantilla = document.getElementById("plantilla-linea");
        var totalGeneral = document.getElementById("total-general");

        function renumerar() {
            cuerpo.querySelectorAll("tr.linea-detalle").forEach(function (fila, i) {
                fila.querySelectorAll("input").forEach(function (input) {
                    input.name = input.name.replace(/Detalles\[(\d+|__INDEX__)\]/, "Detalles[" + i + "]");
                });
            });
        }

        function recalcular() {
            var total = 0;
            cuerpo.querySelectorAll("tr.linea-detalle").forEach(function (fila) {
                var cant = parseFloat(fila.querySelector(".cantidad").value);
                var precio = parseFloat(fila.querySelector(".precio").value);
                var sub = (isNaN(cant) || isNaN(precio)) ? 0 : cant * precio;
                fila.querySelector(".total-linea").textContent = sub.toFixed(2);
                total += sub;
            });
            totalGeneral.textContent = total.toFixed(2);
        }

        function agregar() {
            var indice = cuerpo.querySelectorAll("tr.linea-detalle").length;
            var html = plantilla.innerHTML.replace(/__INDEX__/g, indice);
            var contenedor = document.createElement("tbody");
            contenedor.innerHTML = html.trim();
            cuerpo.appendChild(contenedor.firstChild);
            recalcular();
        }

        function quitar(fila) {
            fila.remove();
            renumerar();
            recalcular();
        }

        document.getElementById("agregar-linea").addEventListener("click", agregar);

        cuerpo.addEventListener("click", function (e) {
            if (e.target.classList.contains("quitar-linea")) {
                quitar(e.target.closest("tr.linea-detalle"));
            }
        });

        cuerpo.addEventListener("input", function (e) {
            if (e.target.classList.contains("cantidad") || e.target.classList.contains("precio")) {
                recalcular();
            }
        });

        recalcular();
    })();
</script>
