@model Stock.Web.Services.MovimientoDto
@{
    ViewData["Title"] = "Eliminar movimiento";
}

<h1 class="h3 mb-4">Eliminar movimiento</h1>

<p>¿Confirmás la baja del siguiente movimiento y su detalle?</p>

<dl class="row">
    <dt class="col-sm-3">Tipo</dt>
    <dd class="col-sm-9">@Model.Tipo</dd>
    <dt class="col-sm-3">Número</dt>
    <dd class="col-sm-9">@Model.Numero</dd>
    <dt class="col-sm-3">Fecha</dt>
    <dd class="col-sm-9">@Model.Fecha.ToString("dd/MM/yyyy")</dd>
</dl>

<div class="table-responsive mb-3">
    <table class="table">
        <thead>
            <tr>
                <th>Código</th>
                <th>Descripción</th>
                <th class="text-end">Cantidad</th>
                <th class="text-end">P. Unitario</th>
                <th class="text-end">P. Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.Detalles)
            {
                <tr>
                    <td>@d.Codigo</td>
                    <td>@d.Descripcion</td>
                    <td class="text-end">@d.Cantidad</td>
                    <td class="text-end">@d.PrecioUnitario.ToString("N2")</td>
                    <td class="text-end">@d.PrecioTotal.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<form asp-action="Delete" asp-route-id="@Model.MovimientoId" method="post">
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</form>
