@model Stock.Web.Models.ArticuloViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<input type="hidden" asp-for="ArticuloId" />

<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="Codigo" class="form-label"></label>
        <input asp-for="Codigo" class="form-control" />
        <span asp-validation-for="Codigo" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="Descripcion" class="form-label"></label>
        <input asp-for="Descripcion" class="form-control" />
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="PrecioCosto" class="form-label"></label>
        <input asp-for="PrecioCosto" class="form-control" type="number" step="0.01" min="0" />
        <span asp-validation-for="PrecioCosto" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Margen" class="form-label"></label>
        <input asp-for="Margen" class="form-control" type="number" step="0.01" min="0" />
        <span asp-validation-for="Margen" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="PrecioVenta" class="form-label"></label>
        <input asp-for="PrecioVenta" class="form-control" value="@Model.PrecioVenta.ToString("N2")" readonly disabled />
        <div class="form-text">Se calcula: Costo × (1 + Margen / 100).</div>
    </div>

    <div class="col-md-4">
        <label asp-for="StockMinimo" class="form-label"></label>
        <input asp-for="StockMinimo" class="form-control" type="number" min="0" />
        <span asp-validation-for="StockMinimo" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="PuntoPedido" class="form-label"></label>
        <input asp-for="PuntoPedido" class="form-control" type="number" min="0" />
        <span asp-validation-for="PuntoPedido" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="StockIdeal" class="form-label"></label>
        <input asp-for="StockIdeal" class="form-control" type="number" min="0" />
        <span asp-validation-for="StockIdeal" class="text-danger"></span>
    </div>
</div>
<div class="form-text mt-2">Debe cumplirse Stock Mínimo ≤ Punto de Pedido ≤ Stock Ideal.</div>
