@model Stock.Web.Models.ArticuloViewModel
@{
    ViewData["Title"] = "Editar artículo";
}

<h1 class="h3 mb-4">Editar artículo</h1>

<form asp-action="Edit" asp-route-id="@Model.ArticuloId" method="post">
    <partial name="_Form" model="Model" />
    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
