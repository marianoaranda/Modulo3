@* Pop-up reutilizable de búsqueda de artículos por descripción (LIKE).
   Se abre con window.BuscarArticulo.abrir(input): al elegir una fila, vuelca el código
   en ese input y le dispara 'change' para reusar la lógica de quien lo abrió. *@
<div class="modal fade" id="modal-buscar-articulo" tabindex="-1" aria-hidden="true"
     data-buscar-url="@Url.Action("BuscarArticulos", "Movimientos")">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="max-height:600px;">
            <div class="modal-header">
                <h5 class="modal-title">Buscar artículo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input type="text" id="buscar-descripcion" class="form-control" placeholder="Descripción (vacío = todos)" autocomplete="off" />
                    <button type="button" id="buscar-boton" class="btn btn-primary">Buscar</button>
                </div>
                <div style="max-height:400px; overflow-y:auto;">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light" style="position:sticky; top:0;">
                            <tr>
                                <th style="width:35%">Código</th>
                                <th>Descripción</th>
                            </tr>
                        </thead>
                        <tbody id="buscar-resultados">
                            <tr><td colspan="2" class="text-muted">Ingresá una descripción y presioná Buscar.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Espera a DOMContentLoaded: el bundle de Bootstrap se carga al final del layout.
    document.addEventListener("DOMContentLoaded", function () {
        var modalEl = document.getElementById("modal-buscar-articulo");
        if (!modalEl) {
            return;
        }

        var modal = new bootstrap.Modal(modalEl);
        var buscarUrl = modalEl.getAttribute("data-buscar-url");
        var inputDescripcion = document.getElementById("buscar-descripcion");
        var botonBuscar = document.getElementById("buscar-boton");
        var resultados = document.getElementById("buscar-resultados");
        var objetivo = null; // input que se completará al elegir un artículo

        function pintarResultados(articulos) {
            resultados.innerHTML = "";
            if (!articulos || articulos.length === 0) {
                resultados.innerHTML = '<tr><td colspan="2" class="text-muted">Sin resultados.</td></tr>';
                return;
            }
            articulos.forEach(function (art) {
                var tr = document.createElement("tr");
                tr.style.cursor = "pointer";
                tr.setAttribute("data-codigo", art.codigo);
                tr.innerHTML = "<td>" + art.codigo + "</td><td>" + art.descripcion + "</td>";
                resultados.appendChild(tr);
            });
        }

        function buscar() {
            var descripcion = inputDescripcion.value.trim();
            resultados.innerHTML = '<tr><td colspan="2" class="text-muted">Buscando…</td></tr>';
            fetch(buscarUrl + "?descripcion=" + encodeURIComponent(descripcion), { headers: { "Accept": "application/json" } })
                .then(function (resp) { return resp.ok ? resp.json() : []; })
                .then(pintarResultados)
                .catch(function () {
                    resultados.innerHTML = '<tr><td colspan="2" class="text-danger">No se pudo realizar la búsqueda.</td></tr>';
                });
        }

        function elegir(codigo) {
            if (objetivo) {
                objetivo.value = codigo;
                // 'change' para que quien abrió el pop-up corra su misma lógica de carga manual.
                objetivo.dispatchEvent(new Event("change", { bubbles: true }));
            }
            modal.hide();
        }

        botonBuscar.addEventListener("click", buscar);
        inputDescripcion.addEventListener("keydown", function (e) {
            if (e.key === "Enter") {
                e.preventDefault();
                buscar();
            }
        });
        resultados.addEventListener("click", function (e) {
            var fila = e.target.closest("tr[data-codigo]");
            if (fila) {
                elegir(fila.getAttribute("data-codigo"));
            }
        });
        modalEl.addEventListener("shown.bs.modal", function () { inputDescripcion.focus(); });

        // API pública: abrir el pop-up apuntando al input que debe recibir el código.
        window.BuscarArticulo = {
            abrir: function (input) {
                objetivo = input;
                inputDescripcion.value = "";
                resultados.innerHTML = '<tr><td colspan="2" class="text-muted">Ingresá una descripción y presioná Buscar.</td></tr>';
                modal.show();
            }
        };
    });
</script>
